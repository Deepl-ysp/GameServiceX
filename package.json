{
  "name": "newgameservice",
  "version": "1.0.0",
  "description": "一个基于 Vite + Vue 3 的游戏服务前端界面",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write .",
    "tdev": "tauri dev",
    "tbuild": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "sass-embedded": "^1.100.0",
    "terser": "^5.48.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  },
  "keywords": [
    "game",
    "service",
    "vue",
    "vite",
    "typescript"
  ],
  "author": "Deepl-ysp",
  "license": "ISC"
}
