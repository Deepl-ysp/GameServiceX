{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "newgameservice",
  "version": "0.1.0",
  "identifier": "com.gameservice.tcack",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:6125",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "newgameservice",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "windows": {
      "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "minimumWebview2Version": null,
      "nsis": {
        "languages": ["SimpChinese","English"],
        "displayLanguageSelector": true
      },
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "resources":[
      "./user",
      "./image",
      "./level"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
